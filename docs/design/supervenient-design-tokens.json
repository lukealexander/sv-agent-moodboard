{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Supervenient design tokens (v0.3). W3C Design Tokens Community Group format. Framework-agnostic. Companion to supervenient-brand-and-design-system.md.",

  "color": {
    "$type": "color",
    "canvas":  { "$value": "#FFFFFF", "$description": "Primary light background." },
    "depth":   { "$value": "#0E2841", "$description": "Deep brand dark: dark surfaces, dark-mode canvas, strongest text." },
    "ink":     { "$value": "#0E2841", "$description": "Default text colour. Calm navy, not pure black." },
    "black":   { "$value": "#000000", "$description": "Reserved max-contrast only. Not the default text colour." },

    "neutral": {
      "$description": "Navy-tinted greys. Minimum scale to build calmly.",
      "0":   { "$value": "#FFFFFF" },
      "50":  { "$value": "#F6F8FA", "$description": "App background / subtle surface." },
      "100": { "$value": "#ECEFF3", "$description": "Cards / raised surface." },
      "200": { "$value": "#DCE2E9", "$description": "Borders, dividers." },
      "400": { "$value": "#9AA5B3", "$description": "Placeholder / disabled. Non-essential text only." },
      "600": { "$value": "#5B6675", "$description": "Secondary text. Targets AA on white." },
      "900": { "$value": "#0E2841", "$description": "Primary text. AAA on white." }
    },

    "accent": {
      "$description": "Decorative values are gradients/fills/glow only and must NOT carry text on white. Use 'onLight' for text/icons/UI; 'onDark' on the depth background.",
      "sky": {
        "$description": "Lead accent. Same hue family as depth (blue-anchored).",
        "decorative": { "$value": "#93DAF7" },
        "onLight":    { "$value": "#1668B0" },
        "onDark":     { "$value": "#93DAF7" }
      },
      "peach": {
        "$description": "The only warm accent. Reserve for human, encouraging moments.",
        "decorative": { "$value": "#F3AC89" },
        "onLight":    { "$value": "#B45A30" },
        "onDark":     { "$value": "#F3AC89" }
      },
      "mint": {
        "decorative": { "$value": "#A1E9AB" },
        "onLight":    { "$value": "#1E7A3E" },
        "onDark":     { "$value": "#7FE0A0" }
      },
      "lilac": {
        "$description": "Deepened from the original #EDBDE7 (L84) to #EAA4E0 (L78, S62) for tonal parity with the other accents.",
        "decorative": { "$value": "#EAA4E0" },
        "onLight":    { "$value": "#9A4D8E" },
        "onDark":     { "$value": "#EAA4E0" }
      }
    },

    "semantic": {
      "$description": "Functional colours, separate from brand accents so meaning is never ambiguous. Always pair with an icon and text, never colour alone.",
      "danger":  { "strong": { "$value": "#B3261E" }, "surface": { "$value": "#FBEAE8" }, "onDark": { "$value": "#FF9A90" } },
      "warning": { "strong": { "$value": "#8A5A00" }, "surface": { "$value": "#FCF3E1" }, "onDark": { "$value": "#F5C26B" } },
      "success": { "strong": { "$value": "#1E7A3E" }, "surface": { "$value": "#E7F6EC" }, "onDark": { "$value": "#7FE0A0" } },
      "info":    { "strong": { "$value": "#1668B0" }, "surface": { "$value": "#E6F3FC" }, "onDark": { "$value": "#93DAF7" } }
    },

    "focus": {
      "$description": "Focus ring. Always visible; >=3:1 against its background; never removed.",
      "light": { "$value": "#1668B0" },
      "dark":  { "$value": "#93DAF7" }
    },

    "darkMode": {
      "$description": "On a depth background, map rather than invert.",
      "textPrimary":   { "$value": "#FFFFFF" },
      "textSecondary": { "$value": "#B9C4D2" },
      "surface1":      { "$value": "#15314D" },
      "surface2":      { "$value": "#1C3C5C" }
    },

    "dataviz": {
      "$description": "Categorical order is colour-blind-safe; always pair with labels.",
      "categorical": {
        "1": { "$value": "#1668B0" },
        "2": { "$value": "#B45A30" },
        "3": { "$value": "#1E7A3E" },
        "4": { "$value": "#9A4D8E" },
        "5": { "$value": "#5B6675" }
      },
      "sequential": {
        "1": { "$value": "#E6F3FC" },
        "2": { "$value": "#93DAF7" },
        "3": { "$value": "#1668B0" },
        "4": { "$value": "#0E2841" }
      }
    }
  },

  "layer": {
    "$description": "Signature layering/additive motif. Overlapping translucent fields whose intersection yields an emergent tone (supervenience). Also the way AI involvement is signalled.",
    "groundRule": {
      "$value": "Additive (screen) blending only renders on a dark/deep surface (>= color.depth). On light surfaces it blows out to white and the layers vanish.",
      "$type": "string",
      "$description": "Load-bearing constraint — read before using blendMode.default."
    },
    "requiresDarkGround": {
      "$value": true,
      "$type": "boolean",
      "$description": "blendMode.default (screen) must sit on color.depth or darker. Otherwise switch to onLight technique."
    },
    "blendMode": {
      "onDark":  { "$value": "screen",   "$type": "string", "$description": "Default. Overlaps move toward light. Use ONLY over a dark/deep ground." },
      "onLight": { "$value": "normal",   "$type": "string", "$description": "On light surfaces do NOT screen. Use translucent soft accent tints (normal alpha blend), or place the luminous layer over a depth panel." },
      "shadowOnly": { "$value": "multiply", "$type": "string", "$description": "Reserved for subtle neutral shadows on a light ground. Never multiply accents (produces mud)." }
    },
    "opacity": {
      "$type": "number",
      "ambient":    { "$value": 0.18, "$description": "AI available / underlying: a faint tint or edge." },
      "active":     { "$value": 0.40, "$description": "AI working / contributing: layer brightens." },
      "expressive": { "$value": 0.60, "$description": "Brand imagery and orb compositions (on a deep ground)." }
    }
  },

  "fontFamily": {
    "$type": "fontFamily",
    "base": { "$value": ["Lexend", "system-ui", "sans-serif"] }
  },

  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium":  { "$value": 500 }
  },

  "typography": {
    "$type": "typography",
    "$description": "Composite text styles. Headings Medium, tracked in; body Regular, airy.",
    "display": { "$value": { "fontFamily": "Lexend", "fontWeight": 500, "fontSize": "48px", "lineHeight": 1.10, "letterSpacing": "-0.03em" } },
    "h1":      { "$value": { "fontFamily": "Lexend", "fontWeight": 500, "fontSize": "36px", "lineHeight": 1.15, "letterSpacing": "-0.025em" } },
    "h2":      { "$value": { "fontFamily": "Lexend", "fontWeight": 500, "fontSize": "28px", "lineHeight": 1.20, "letterSpacing": "-0.02em" } },
    "h3":      { "$value": { "fontFamily": "Lexend", "fontWeight": 500, "fontSize": "22px", "lineHeight": 1.30, "letterSpacing": "-0.01em" } },
    "bodyLarge": { "$value": { "fontFamily": "Lexend", "fontWeight": 400, "fontSize": "18px", "lineHeight": 1.55, "letterSpacing": "0" } },
    "body":    { "$value": { "fontFamily": "Lexend", "fontWeight": 400, "fontSize": "16px", "lineHeight": 1.55, "letterSpacing": "0" } },
    "small":   { "$value": { "fontFamily": "Lexend", "fontWeight": 400, "fontSize": "14px", "lineHeight": 1.45, "letterSpacing": "0" } },
    "caption": { "$value": { "fontFamily": "Lexend", "fontWeight": 400, "fontSize": "12px", "lineHeight": 1.40, "letterSpacing": "0" } }
  },

  "spacing": {
    "$type": "dimension",
    "$description": "Base unit 4px; primary rhythm 8px.",
    "0": { "$value": "2px" },
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "24px" },
    "6": { "$value": "32px" },
    "7": { "$value": "48px" },
    "8": { "$value": "64px" },
    "9": { "$value": "96px" }
  },

  "radius": {
    "$type": "dimension",
    "sm":   { "$value": "6px" },
    "md":   { "$value": "10px" },
    "lg":   { "$value": "16px" },
    "xl":   { "$value": "24px" },
    "pill": { "$value": "999px" }
  },

  "elevation": {
    "$type": "shadow",
    "$description": "Diffuse, navy-tinted shadows. Never pure black.",
    "e1": { "$value": [
      { "color": "rgba(14,40,65,0.10)", "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px" },
      { "color": "rgba(14,40,65,0.06)", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
    ] },
    "e2": { "$value": { "color": "rgba(14,40,65,0.08)", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px" } },
    "e3": { "$value": { "color": "rgba(14,40,65,0.12)", "offsetX": "0px", "offsetY": "12px", "blur": "40px", "spread": "0px" }, "$description": "Modals and orb glow." }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "120ms" },
      "base": { "$value": "180ms" },
      "slow": { "$value": "240ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "calm": { "$value": [0.2, 0, 0, 1], "$description": "Decelerate. Honour prefers-reduced-motion." }
    }
  },

  "accessibility": {
    "$description": "Constraints, not styling. WCAG 2.2 AA.",
    "minTextContrast":   { "$value": 4.5, "$type": "number" },
    "minLargeContrast":  { "$value": 3.0, "$type": "number" },
    "minTouchTargetPx":  { "$value": 44, "$type": "number" },
    "minBodyFontPx":     { "$value": 16, "$type": "number" },
    "neverColourAlone":  { "$value": true, "$type": "boolean", "$description": "Meaning must also be carried by icon and/or text." }
  }
}
