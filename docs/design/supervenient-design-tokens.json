{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Supervenient design tokens (v0.6). W3C Design Tokens Community Group format. Framework-agnostic (no Tailwind). Companion to supervenient-brand-and-design-system.md. Model: ground - facets - spark.",

  "color": {
    "$type": "color",

    "ground": {
      "$description": "The substrate. Tier 1.",
      "core":  { "$value": "#4F2270", "$description": "Brand purple: primary text and mid surfaces (~11.6:1 on white)." },
      "depth": { "$value": "#241036", "$description": "Deep aubergine: dark canvas/hero — the ground the facets and spark glow against." }
    },
    "ink": { "$value": "#4F2270", "$description": "Default text colour (= ground.core). Calm violet, not pure black." },

    "neutral": {
      "$description": "Purple-tinted greys.",
      "0":      { "$value": "#FFFFFF" },
      "canvas": { "$value": "#FBFAFD", "$description": "App background (faint violet white)." },
      "50":     { "$value": "#F4F1F8", "$description": "Subtle surface." },
      "100":    { "$value": "#ECE7F2", "$description": "Cards / raised surface." },
      "200":    { "$value": "#DED5EA", "$description": "Borders, dividers." },
      "400":    { "$value": "#9C90AE", "$description": "Placeholder / disabled. Non-essential text only." },
      "600":    { "$value": "#5E5470", "$description": "Secondary text (~7:1 on white)." }
    },

    "facet": {
      "$description": "Tier 2 — the parts. Decorative values are fills/gradients only and must NOT carry text on white. Use 'ink' for text/icons/UI; 'onDark' on the depth ground. Blend in gradients, do not tile flat blocks.",
      "gold": {
        "$description": "Warm lead facet. The only warm facet — reserve for human, encouraging moments.",
        "decorative": { "$value": "#FFC000" },
        "ink":        { "$value": "#8A5E00" },
        "onDark":     { "$value": "#FFC000" }
      },
      "green": {
        "decorative": { "$value": "#8ED973" },
        "ink":        { "$value": "#1E7A3E" },
        "onDark":     { "$value": "#8ED973" }
      },
      "teal": {
        "decorative": { "$value": "#2FB6D4" },
        "ink":        { "$value": "#0E7088" },
        "onDark":     { "$value": "#2FB6D4" }
      },
      "magenta": {
        "$description": "Optional fourth facet — richer kaleidoscopes and a fifth data series.",
        "decorative": { "$value": "#D45BB0" },
        "ink":        { "$value": "#9A2F80" },
        "onDark":     { "$value": "#D45BB0" }
      }
    },

    "spark": {
      "$description": "Tier 3 — the whole. The point where facets converge. The most powerful colour in the set BECAUSE it is rationed.",
      "color":          { "$value": "#FFFF00", "$type": "color" },
      "pointScaleOnly": { "$value": true, "$type": "boolean", "$description": "A node, marker or single highlight — never a fill or large area." },
      "darkGroundOnly": { "$value": true, "$type": "boolean", "$description": "Reads on ground.core or darker; ~1.1:1 on white (invisible by design)." },
      "onePerView":     { "$value": true, "$type": "boolean", "$description": "At most one spark per screen; a second cancels the first." },
      "neverSemantic":  { "$value": true, "$type": "boolean", "$description": "Not a warning colour. Warning uses facet.gold.ink + icon." }
    },

    "semantic": {
      "$description": "Three of four share a hue with a facet, so meaning MUST be carried by icon + text — colour is reinforcement only. Danger (red) is the chromatically distinct one. The spark is never used semantically.",
      "danger":  { "strong": { "$value": "#B3261E" }, "surface": { "$value": "#FBEAE8" }, "onDark": { "$value": "#FF9A90" } },
      "warning": { "strong": { "$value": "#8A5E00" }, "surface": { "$value": "#FDF1D6" }, "onDark": { "$value": "#FFC000" } },
      "success": { "strong": { "$value": "#1E7A3E" }, "surface": { "$value": "#E9F8E6" }, "onDark": { "$value": "#8ED973" } },
      "info":    { "strong": { "$value": "#0E7088" }, "surface": { "$value": "#DBF1F6" }, "onDark": { "$value": "#2FB6D4" } }
    },

    "focus": {
      "$description": "Focus ring. Always visible; >=3:1 against background; never removed.",
      "light": { "$value": "#7B4BA8" },
      "dark":  { "$value": "#2FB6D4" }
    },

    "darkMode": {
      "$description": "On a depth ground, map rather than invert.",
      "textPrimary":   { "$value": "#FFFFFF" },
      "textSecondary": { "$value": "#C9BBDD" },
      "surface1":      { "$value": "#341852" },
      "surface2":      { "$value": "#432063" }
    },

    "dataviz": {
      "$description": "Categorical order is colour-blind-safe; always pair with labels. Spark highlights one point only.",
      "categorical": {
        "1": { "$value": "#FFC000" },
        "2": { "$value": "#2FB6D4" },
        "3": { "$value": "#8ED973" },
        "4": { "$value": "#D45BB0" },
        "5": { "$value": "#4F2270" }
      },
      "sequential": {
        "1": { "$value": "#DBF1F6" },
        "2": { "$value": "#2FB6D4" },
        "3": { "$value": "#0E7088" },
        "4": { "$value": "#241036" }
      },
      "highlight": { "$value": "#FFFF00", "$description": "The spark — one point only, on a deep chart ground." }
    }
  },

  "motif": {
    "$description": "Kaleidoscope / convergence. Facets resolving into a whole at a spark.",
    "groundRule": {
      "$value": "Luminous effects (facet blends, kaleidoscope, spark) only render on a deep ground (>= color.ground.depth). On light surfaces use solid facet fills, ink variants and soft tints — no glow on white.",
      "$type": "string",
      "$description": "Load-bearing constraint."
    },
    "blendMode": {
      "onDark":  { "$value": "screen", "$type": "string", "$description": "Facet blends/kaleidoscope on a dark ground move toward light." },
      "onLight": { "$value": "normal", "$type": "string", "$description": "On light surfaces use solid fills / soft tints, not screen." }
    }
  },

  "fontFamily": {
    "$type": "fontFamily",
    "base": { "$value": ["Lexend", "system-ui", "sans-serif"] }
  },

  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium":  { "$value": 500 }
  },

  "typography": {
    "$type": "typography",
    "$description": "Composite text styles. Headings Medium, tracked in; body Regular, airy.",
    "display": { "$value": { "fontFamily": "Lexend", "fontWeight": 500, "fontSize": "48px", "lineHeight": 1.10, "letterSpacing": "-0.03em" } },
    "h1":      { "$value": { "fontFamily": "Lexend", "fontWeight": 500, "fontSize": "36px", "lineHeight": 1.15, "letterSpacing": "-0.025em" } },
    "h2":      { "$value": { "fontFamily": "Lexend", "fontWeight": 500, "fontSize": "28px", "lineHeight": 1.20, "letterSpacing": "-0.02em" } },
    "h3":      { "$value": { "fontFamily": "Lexend", "fontWeight": 500, "fontSize": "22px", "lineHeight": 1.30, "letterSpacing": "-0.01em" } },
    "bodyLarge": { "$value": { "fontFamily": "Lexend", "fontWeight": 400, "fontSize": "18px", "lineHeight": 1.55, "letterSpacing": "0" } },
    "body":    { "$value": { "fontFamily": "Lexend", "fontWeight": 400, "fontSize": "16px", "lineHeight": 1.55, "letterSpacing": "0" } },
    "small":   { "$value": { "fontFamily": "Lexend", "fontWeight": 400, "fontSize": "14px", "lineHeight": 1.45, "letterSpacing": "0" } },
    "caption": { "$value": { "fontFamily": "Lexend", "fontWeight": 400, "fontSize": "12px", "lineHeight": 1.40, "letterSpacing": "0" } }
  },

  "spacing": {
    "$type": "dimension",
    "$description": "Base unit 4px; primary rhythm 8px.",
    "0": { "$value": "2px" }, "1": { "$value": "4px" }, "2": { "$value": "8px" },
    "3": { "$value": "12px" }, "4": { "$value": "16px" }, "5": { "$value": "24px" },
    "6": { "$value": "32px" }, "7": { "$value": "48px" }, "8": { "$value": "64px" }, "9": { "$value": "96px" }
  },

  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" }, "md": { "$value": "10px" }, "lg": { "$value": "16px" },
    "xl": { "$value": "24px" }, "pill": { "$value": "999px" }
  },

  "elevation": {
    "$type": "shadow",
    "$description": "Diffuse, aubergine-tinted shadows. Never pure black.",
    "e1": { "$value": [
      { "color": "rgba(36,16,54,0.12)", "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px" },
      { "color": "rgba(36,16,54,0.07)", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
    ] },
    "e2": { "$value": { "color": "rgba(36,16,54,0.12)", "offsetX": "0px", "offsetY": "6px", "blur": "20px", "spread": "0px" } },
    "e3": { "$value": { "color": "rgba(36,16,54,0.22)", "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px" }, "$description": "Modals and brand moments." }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "120ms" }, "base": { "$value": "180ms" }, "slow": { "$value": "240ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "calm": { "$value": [0.2, 0, 0, 1], "$description": "Decelerate. Honour prefers-reduced-motion." }
    }
  },

  "accessibility": {
    "$description": "Constraints, not styling. WCAG 2.2 AA.",
    "minTextContrast":  { "$value": 4.5, "$type": "number" },
    "minLargeContrast": { "$value": 3.0, "$type": "number" },
    "minTouchTargetPx": { "$value": 44, "$type": "number" },
    "minBodyFontPx":    { "$value": 16, "$type": "number" },
    "neverColourAlone": { "$value": true, "$type": "boolean", "$description": "Meaning must also be carried by icon and/or text — especially given facet/semantic hue overlap." }
  }
}