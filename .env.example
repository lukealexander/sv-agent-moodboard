# Copy to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Global ────────────────────────────────────────────────────────────────────
LOCAL_DEV=true

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/app

# CORS — required when LOCAL_DEV=false; comma-separated list of allowed origins
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# Cognito (only needed when LOCAL_DEV=false).
# The API validates access tokens at the POOL level (issuer + signature +
# token_use), so it needs the pool id + region — NOT an app client id.
# Tip: run ./scripts/fetch-cognito-config.sh to fill these from the platform's SSM.
COGNITO_USER_POOL_ID=eu-west-2_XXXXXXXXX
COGNITO_REGION=eu-west-2
# Hosted UI domain (bare host). Lets the API enrich claims with the caller's
# email via the OIDC userInfo endpoint (/whoami, require_user). Empty = no email.
COGNITO_DOMAIN=auth.labs.supervenient.ai
# Optional defense-in-depth: comma-separated app client ids allowed to call the
# API. Empty = accept any client in the pool (cross-service / api-to-api).
# COGNITO_ALLOWED_CLIENT_IDS=

# ── Frontend ──────────────────────────────────────────────────────────────────
# The frontend DOES need the app client id (it logs in against that client). For
# real-Cognito local login (LOCAL_DEV=false) this is the platform's dev-only
# local-dev client — the only client registering http://localhost:5173 URLs —
# fetched by ./scripts/fetch-cognito-config.sh.
VITE_API_BASE_URL=http://localhost:8000
VITE_COGNITO_DOMAIN=auth.labs.supervenient.ai
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_USER_POOL_ID=eu-west-2_XXXXXXXXX
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/callback
